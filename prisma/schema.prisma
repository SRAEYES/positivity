generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  imageUrl    String?
  age         Int?
  country     String?
  state       String?
  location    String?
  parentName  String?
  parentRel   String?
  createdAt   DateTime     @default(now())
  role        String       @default("student")
  streakCount Int          @default(0)
  lastLogin   DateTime?
  enrollments Enrollment[]
  japaGoals   JapaGoal[]
  journals    SpiritualJournal[]
  bookmarks   LibraryBookmark[]
  perks       UserPerk[]
  results     QuizResult[]
}

model TeacherProfile {
  id            Int      @id @default(autoincrement())
  name          String
  qualifications String
  experience    String
  bio           String?
  imageUrl      String?
  updatedAt     DateTime @updatedAt
}

model Course {
  id          Int          @id @default(autoincrement())
  title       String
  thumbnail   String?
  timeslot    String?
  wpLink      String?
  gcrLink     String?
  description String?
  startDate   DateTime?
  price       Float        @default(0)
  pricingType String       @default("ONETIME") // ONETIME or SUBSCRIPTION
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  enrollments Enrollment[]
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  paid      Boolean  @default(false)
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  payment   Payment?
}

model Payment {
  id           Int        @id @default(autoincrement())
  enrollmentId Int        @unique
  provider     String
  providerId   String?
  amount       Int
  status       String
  createdAt    DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("info") // info, wisdom, alert
  isGlobal  Boolean  @default(true)
  userId    Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model JapaGoal {
  id               Int            @id @default(autoincrement())
  userId           Int
  mantraName       String
  dailyRoundsGoal  Int            @default(16)
  theme            String?        @default("krishna")
  createdAt        DateTime       @default(now())
  user             User           @relation(fields: [userId], references: [id])
  progress         JapaProgress[]
}

model JapaProgress {
  id              Int      @id @default(autoincrement())
  goalId          Int
  roundsCompleted Int
  date            DateTime @default(now())
  goal            JapaGoal @relation(fields: [goalId], references: [id])
}

model SpiritualJournal {
  id         Int      @id @default(autoincrement())
  userId     Int
  bookName   String
  pagesRead  Int
  notes      String?
  mediaUrl   String?
  mediaType  String? // image, voice
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model LibraryBook {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  coverUrl    String?
  contentUrl  String? // for PDF or Markdown content
  description String?
  bookmarks   LibraryBookmark[]
}

model LibraryBookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int
  page      Int?
  chapter   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  book      LibraryBook @relation(fields: [bookId], references: [id])
}

model Perk {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  type        String     @default("gift") // chocolate, gift, book, access
  imageUrl    String?
  unlockedBy  UserPerk[]
}

model UserPerk {
  id         Int      @id @default(autoincrement())
  userId     Int
  perkId     Int
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  perk       Perk     @relation(fields: [perkId], references: [id])
}

model Quiz {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  questions   QuizQuestion[]
  results     QuizResult[]
}

model QuizQuestion {
  id            Int    @id @default(autoincrement())
  quizId        Int
  text          String
  options       String // JSON stringified array
  correctAnswer String
  quiz          Quiz         @relation(fields: [quizId], references: [id])
}

model QuizResult {
  id        Int      @id @default(autoincrement())
  userId    Int
  quizId    Int
  score     Int
  total     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  quiz      Quiz     @relation(fields: [quizId], references: [id])
}
