generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  age         Int?
  country     String?
  state       String?
  location    String?
  parentName  String?
  parentRel   String?
  createdAt   DateTime     @default(now())
  role        String       @default("student")
  enrollments Enrollment[]
  japaGoals   JapaGoal[]
  journals    SpiritualJournal[]
}

model Course {
  id          Int          @id @default(autoincrement())
  title       String
  thumbnail   String?
  timeslot    String?
  wpLink      String?
  gcrLink     String?
  description String?
  startDate   DateTime?
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  paid      Boolean  @default(false)
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  payment   Payment?
}

model Payment {
  id           Int        @id @default(autoincrement())
  enrollmentId Int        @unique
  provider     String
  providerId   String?
  amount       Int
  status       String
  createdAt    DateTime   @default(now())
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("info") // info, wisdom, alert
  isGlobal  Boolean  @default(true)
  userId    Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model JapaGoal {
  id               Int            @id @default(autoincrement())
  userId           Int
  mantraName       String
  dailyRoundsGoal  Int            @default(16)
  theme            String?        @default("krishna")
  createdAt        DateTime       @default(now())
  user             User           @relation(fields: [userId], references: [id])
  progress         JapaProgress[]
}

model JapaProgress {
  id              Int      @id @default(autoincrement())
  goalId          Int
  roundsCompleted Int
  date            DateTime @default(now())
  goal            JapaGoal @relation(fields: [goalId], references: [id])
}

model SpiritualJournal {
  id         Int      @id @default(autoincrement())
  userId     Int
  bookName   String
  pagesRead  Int
  notes      String?
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
